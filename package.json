{
  "name": "walk-the-spec",
  "version": "1.0.23",
  "description": "Walk the Spec",
  "author": "joao-januario",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/joao-januario/Walk-the-Spec.git"
  },
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "predev": "bash scripts/sync-scaffold.sh",
    "dev": "electron-vite dev",
    "prebuild": "bash scripts/sync-scaffold.sh",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "sync-scaffold": "bash scripts/sync-scaffold.sh",
    "sync-scaffold:check": "bash scripts/sync-scaffold.sh --check",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac --x64",
    "dist:mac-arm64": "npm run build && electron-builder --mac --arm64",
    "dist:mac-universal": "npm run build && electron-builder --mac --x64 --arm64",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "electronVersion": "33.4.11",
    "appId": "com.speckit.walk-the-spec",
    "productName": "Walk the Spec",
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "files": [
      "out/**/*"
    ],
    "asarUnpack": [],
    "extraResources": [
      {
        "from": "resources/scaffold",
        "to": "scaffold"
      },
      {
        "from": "resources/sounds",
        "to": "sounds"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "identity": null,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "target": "AppImage"
    },
    "publish": {
      "provider": "github",
      "owner": "joao-januario",
      "repo": "Walk-the-Spec",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "chokidar": "^4.0.0",
    "clsx": "^2.1.1",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.7.0",
    "mermaid": "^11.13.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "unified": "^11.0.0",
    "unist-util-visit": "^5.0.0",
    "uuid": "^10.0.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
